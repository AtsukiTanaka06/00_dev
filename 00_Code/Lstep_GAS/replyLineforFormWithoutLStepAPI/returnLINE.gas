const OPENAI_API_KEY = "YOUR_OPENAI_API_KEY_HERE";
const LINE_CHANNEL_ACCESS_TOKEN = "YOUR_LINE_CHANNEL_ACCESS_TOKEN_HERE";

const FORM_SHEET_NAME = "シート1";
const LSTEP_MAP_SHEET = "LStep_MAP";
const LINE_MAP_SHEET = "LineID_MAP";
const FOLLOW_EVENT_SHEET = "Event_Follow";
const POSTBACK_EVENT_SHEET = "Event_Postback";

function onSheetChange(e) {
  try {
    /*
    const sheet = e.source.getActiveSheet();

    // 対象シート以外は何もしない
    if (sheet.getName() !== FORM_SHEET_NAME) {
      return;
    }

    writeLog("INFO", "onSheetChange", "START", "処理開始", e?.changeType);
*/
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const formSheet = ss.getSheetByName(FORM_SHEET_NAME);

    if (!formSheet) {
      writeLog("ERROR", "onSheetChange", "SHEET_CHECK", "フォームシートが見つかりません");
      return;
    }

    const lastRow = formSheet.getLastRow();
    if (lastRow < 2) {
      writeLog("WARN", "onSheetChange", "ROW_CHECK", "データ行が存在しません");
      return;
    }

    const lastCol = formSheet.getLastColumn();
    const headers = formSheet.getRange(1, 1, 1, lastCol).getValues()[0];
    const values = formSheet.getRange(lastRow, 1, 1, lastCol).getValues()[0];

    const data = {};
    headers.forEach((h, i) => data[h] = values[i]);

    writeLog("INFO", "onSheetChange", "DATA_LOADED", "フォームデータ取得", data);

    // ===== LStepID =====
    const lstepId = data["回答者ID"];
    if (!lstepId) {
      writeLog("ERROR", "onSheetChange", "LSTEP_ID", "回答者IDが空", data);
      writeFormAnswerLog("送信失敗",data["回答ID"],data["回答日時"],data["回答者ID"],data["回答者名"])
      return;
    }

    // ===== Line名 =====
    const lineName = getLineNameByLStepId(lstepId);
    //const lineName = getLineNameByLStepId(9999);
    if (!lineName) {
      writeLog("ERROR", "onSheetChange", "LINE_NAME", "Line名取得失敗", { lstepId });
      writeFormAnswerLog("送信失敗",data["回答ID"],data["回答日時"],data["回答者ID"],data["回答者名"]);
      notifyLineError()
      return;
    }

    // ===== LineID =====
    const lineId = getLineIDByLineName(lineName);
    if (!lineId) {
      writeLog("ERROR", "onSheetChange", "LINE_ID", "LineID取得失敗", { lineName });
      writeFormAnswerLog("送信失敗",data["回答ID"],data["回答日時"],data["回答者ID"],data["回答者名"]);
      return;
    }

    if(lineId.length > 1){
      writeLog("ERROR", "onSheetChange", "LINE_ID", "LineID取得失敗_LINE名重複", { lineName });
      writeFormAnswerLog("送信失敗",data["回答ID"],data["回答日時"],data["回答者ID"],data["回答者名"]);
      notifyLineError('ERROR',data["回答ID"],data["回答内容"],lineName)
      return;     
    }

    // ===== ChatGPT 呼び出し =====
    //const prompt = buildPrompt(data);
    //const gptResponse = callChatGPT(prompt);

    // ===== LINE送信 =====
    //sendLineMessage(lineId, gptResponse);
    sendLineMessage(lineId[0], "テスト中");
    writeLog("INFO", "onSheetChange", "LINE_SEND", "LINE送信成功", { lineId });
    writeFormAnswerLog("送信成功",data["回答ID"],data["回答日時"],data["回答者ID"],data["回答者名"]);

  } catch (err) {
    writeLog(
      "ERROR",
      "onSheetChange",
      "EXCEPTION",
      err.message,
      { stack: err.stack }
    );
    writeFormAnswerLog("送信失敗",data["回答ID"],data["回答日時"],data["回答者ID"],data["回答者名"]);
  }
}

//*****ChatGPT 呼び出し*****
function callChatGPT(promptText) {
  const url = "https://api.openai.com/v1/chat/completions";

  const payload = {
    model: "gpt-4o-mini",
    messages: [
      { role: "system", content: "あなたはユーザーに対して丁寧で分かりやすく返信するアシスタントです。" },
      { role: "user", content: promptText }
    ],
    max_tokens: 500
  };

  const options = {
    method: "post",
    contentType: "application/json",
    headers: {
      Authorization: `Bearer ${OPENAI_API_KEY}`
    },
    payload: JSON.stringify(payload)
  };

  const res = UrlFetchApp.fetch(url, options);
  const json = JSON.parse(res.getContentText());
  return json.choices[0].message.content;
}

//*****プロンプト生成 *****
function buildPrompt(data) {
  let text = "以下はフォームから送信された内容です。\n\n";
  for (const key in data) {
    text += `【${key}】\n${data[key]}\n\n`;
  }
  text += "この内容に対して、ユーザーに返信する文章を作成してください。";
  return text;
}

//*****LStepID → LINE登録名へ 変換*****
function getLineNameByLStepId(lstepId) {
  const sheet = SpreadsheetApp
    .getActiveSpreadsheet()
    .getSheetByName(LSTEP_MAP_SHEET);

  const values = sheet.getRange(2, 1, sheet.getLastRow() - 1, 3).getValues();

  for (const row of values) {
    if (String(row[0]) === String(lstepId)) {
      return row[2]; // LineID
    }
  }
  return null;
}

function getLineIDByLineName(lineName) {
  writeLog("INFO", "getLineIDByLineName", "START", "探索開始", lineName);

  let lineID = getLineIDByLineNameFromLineMap(lineName);
  if (lineID) {
    writeLog("INFO", "getLineIDByLineName", "LINE_MAP", "LINE_MAPから取得", lineID);
    return lineID;
  }

  const resolvers = [
    getLineIDByLineNameFromFollowEvent,
    getLineIDByLineNameFromPostbackEvent,
  ];

  for (const resolver of resolvers) {
    lineID = resolver(lineName);
    if (lineID) {
      writeLog("INFO", "getLineIDByLineName", "EVENT", "イベント経由で取得", lineID);
      addUserToSheet(LINE_MAP_SHEET, lineID, lineName);
      return lineID;
    }
  }

  writeLog("WARN", "getLineIDByLineName", "NOT_FOUND", "LineIDが見つからない", lineName);
  return null;
}

//*****LINE登録名 → LINE IDへ 変換(LINE_MAP_SHEETから）*****
function getLineIDByLineNameFromLineMap(lineName) {
  const sheet = SpreadsheetApp
    .getActiveSpreadsheet()
    .getSheetByName(LINE_MAP_SHEET);

  let retValue = [];
  
  const lastRow = sheet.getLastRow();

  if (lastRow <= 1) {
    return null; // データなし
  }

  const values = sheet.getRange(2, 1, lastRow - 1, 3).getValues();

  for (const row of values) {
    if (String(row[1]) === String(lineName)) {
      retValue.push(row[0]);
    }
  }

  return retValue;
}

//*****LINE登録名 → LINE IDへ 変換（FOLLOW_EVENT_SHEETから）*****
function getLineIDByLineNameFromFollowEvent(lineName) {
  const sheet = SpreadsheetApp
    .getActiveSpreadsheet()
    .getSheetByName(FOLLOW_EVENT_SHEET);
    
  let retValue = [];
  const lastRow = sheet.getLastRow();

  if (lastRow <= 1) {
    return null; // データなし
  }

  const values = sheet.getRange(2, 1, lastRow - 1, 3).getValues();

  for (const row of values) {
    if (String(row[2]) === String(lineName)) {
      retValue.push(row[1]);
    }
  }
  return retValue;
}

//*****LINE登録名 → LINE IDへ 変換（POSTEVENT_EVENT_SHEETから）*****
function getLineIDByLineNameFromPostbackEvent(lineName) {
  const sheet = SpreadsheetApp
    .getActiveSpreadsheet()
    .getSheetByName(POSTBACK_EVENT_SHEET);

  let retValue = [];
  const lastRow = sheet.getLastRow();

  if (lastRow <= 1) {
    return null; // データなし
  }

  const values = sheet.getRange(2, 1, lastRow - 1, 3).getValues();

  for (const row of values) {
    if (String(row[2]) === String(lineName)) {
      retValue.push(row[1]);
    }
  }
  return null;
}

/**
 * 指定シートの最終行に値を追加する
 * @param {string} sheetName - シート名
 * @param {string} userId - ユーザーID
 * @param {string} lineDisplayName - LINE表示名
 */
function addUserToSheet(sheetName, userId, lineDisplayName) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    throw new Error(`シートが見つかりません: ${sheetName}`);
  }

  // 最終行の次の行番号
  const nextRow = sheet.getLastRow() + 1;

  // A列: ユーザーID, B列: LINE表示名
  sheet.getRange(nextRow, 1, 1, 2).setValues([
    [userId, lineDisplayName]
  ]);
}


//****LINE Messaging API 送信 ******
function sendLineMessage(lineUserId, message) {
  const url = "https://api.line.me/v2/bot/message/push";

  const payload = {
    to: lineUserId,
    messages: [
      {
        type: "text",
        text: message
      }
    ]
  };

  const options = {
    method: "post",
    contentType: "application/json",
    headers: {
      Authorization: `Bearer ${LINE_CHANNEL_ACCESS_TOKEN}`
    },
    payload: JSON.stringify(payload)
  };

  UrlFetchApp.fetch(url, options);
}

/**
 * Line グループへの通知用
 * LINE名が重複した際にLINEグループへ通知し、手動で対応を促す
 */
function notifyLineError(level, answerID, answer, lineUserName, detail = "") {
  if (level !== "ERROR") return;

  const groupId = getSettingValue("LINE_ERROR_GROUP_ID");
  if (!groupId) {
    Logger.log("LINE_ERROR_GROUP_ID が Setting に存在しません");
    return;
  }

  const text =
`🚨【GASエラー通知】

■ 発生時刻
${Utilities.formatDate(new Date(), "Asia/Tokyo", "yyyy/MM/dd HH:mm:ss")}

■ 回答ID
${answerID}

■ 回答内容
${answer}

■ 回答者（LINE名）
${lineUserName}

■ 内容
ライン名が重複しているため、回答者の特定ができませんでした。\r\n
手動にて回答をしてください。

■ 詳細
${typeof detail === "object" ? JSON.stringify(detail, null, 2) : detail}
`;

  sendLineMessage(groupId, text);
}

function getSettingValue(key) {
  const sheet = SpreadsheetApp
    .getActiveSpreadsheet()
    .getSheetByName("Setting");

  if (!sheet) {
    throw new Error("Setting シートが見つかりません");
  }

  const lastRow = sheet.getLastRow();
  if (lastRow < 1) return null;

  const values = sheet.getRange(1, 1, lastRow, 2).getValues();

  for (const row of values) {
    if (row[0] === key) {
      return row[1];
    }
  }
  return null;
}


/**
 * Logger シートに回答への返信の成功/失敗のステータスを書き込む
 */

const LOG_SHEET = "Log";

function writeFormAnswerLog(status,answerId,answerDate,lstepId,answerName) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName(LOG_SHEET);
    if (!sheet) return;

    const nowJST = Utilities.formatDate(
      new Date(),
      "Asia/Tokyo",
      "yyyy/MM/dd HH:mm:ss"
    );

    sheet.appendRow([
      nowJST,
      status,
      answerId,
      answerDate,
      lstepId,
      answerName,
    ]);
  } catch (e) {
    // ログ失敗時は Logger.log のみ
    Logger.log("LOG ERROR: " + e);
  }
}

const LOGGER_SHEET = "Logger";

/**
 * Logger シートにログを書き込む
 */
function writeLog(level, funcName, step, message, detail = "") {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName(LOGGER_SHEET);
    if (!sheet) return;

    const nowJST = Utilities.formatDate(
      new Date(),
      "Asia/Tokyo",
      "yyyy/MM/dd HH:mm:ss"
    );

    sheet.appendRow([
      nowJST,
      level,
      funcName,
      step,
      message,
      typeof detail === "object" ? JSON.stringify(detail) : detail
    ]);
  } catch (e) {
    // ログ失敗時は Logger.log のみ
    Logger.log("LOGGING ERROR: " + e);
  }
}

/**
 * ログ肥大化防止のため、時間主導トリガーで定期実行の設定が必要
 */
function deleteOldLogs() {
  const SHEET_NAME = 'Logger';
  const KEEP_DAYS = 7;

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAME);
  if (!sheet) return;

  const lastRow = sheet.getLastRow();
  if (lastRow <= 1) return; // ヘッダーのみ

  const now = new Date();
  const limitDate = new Date(now.getTime() - KEEP_DAYS * 24 * 60 * 60 * 1000);

  const values = sheet.getRange(2, 1, lastRow - 1, 1).getValues();

  // 削除対象行を後ろから削除（重要）
  for (let i = values.length - 1; i >= 0; i--) {
    const logDate = values[i][0];
    if (logDate instanceof Date && logDate < limitDate) {
      sheet.deleteRow(i + 2);
    }
  }
}
