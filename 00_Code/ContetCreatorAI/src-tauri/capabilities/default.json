{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for ContentCreatorAI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "http:default",
    "http:allow-fetch-send",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://api.notion.com/**" }
      ]
    }
  ]
}
